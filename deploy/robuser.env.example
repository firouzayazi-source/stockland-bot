BOT_TOKEN=
ADMIN_ID=
BOT_USERNAME=stock_land_bot

# One DB only:
DB_PATH=/var/lib/robuser/db.sqlite

# Payments
ZARINPAL_MERCHANT_ID=
ZARINPAL_SANDBOX=0
BASE_CALLBACK_URL=https://YOUR-RAILWAY-DOMAIN.up.railway.app/payment/callback
PAYMENT_API_BASE_URL=http://127.0.0.1:8000
MIN_TOPUP_AMOUNT=10000

# Railway/single-service mode:
# The FastAPI payment service starts Telegram polling in the same container.
RUN_BOT_IN_PAYMENT_SERVICE=1
